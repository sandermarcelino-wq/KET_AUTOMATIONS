TAVILY_API_KEY=tvly-YOUR_API_KEY_HERE

# Telegram Admin Bot (admin_interface.py)
# Crie seu bot com @BotFather e cole o token abaixo
TELEGRAM_BOT_TOKEN=1234567890:AAF...seu_token_aqui

# Restringe o bot ao seu chat pessoal (recomendado)
# Descubra seu chat ID enviando uma mensagem para @userinfobot
TELEGRAM_ADMIN_CHAT_ID=seu_chat_id_aqui

# URL base do storage de assets (ex: Supabase Storage público ou VPS própria)
# Usado pelo admin_interface.py (link do anúncio) e meta_auto_publisher.py (URL pública para a API do Meta)
# Exemplo Supabase: https://xxx.supabase.co/storage/v1/object/public/campaign-uploads
# Exemplo VPS:      https://assets.seudominio.com.br/ket
BASE_URL_ASSETS=https://seu-storage.supabase.co/storage/v1/object/public/campaign-uploads

# Meta Graph API — Instagram Content Publishing (meta_auto_publisher.py)
# Token com permissão: instagram_content_publish, pages_read_engagement
# Gere em: https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN=EAAxxxxxxxxxx...seu_token_aqui

# ID numérico da conta Instagram Business/Creator
# Encontre em: GET /me/accounts → cada page tem um campo instagram_business_account.id
INSTAGRAM_USER_ID=17841400000000000

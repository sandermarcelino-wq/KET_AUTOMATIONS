TAVILY_API_KEY=tvly-YOUR_API_KEY_HERE

# Telegram Admin Bot (admin_interface.py)
# Crie seu bot com @BotFather e cole o token abaixo
TELEGRAM_BOT_TOKEN=1234567890:AAF...seu_token_aqui

# Restringe o bot ao seu chat pessoal (recomendado)
# Descubra seu chat ID enviando uma mensagem para @userinfobot
TELEGRAM_ADMIN_CHAT_ID=seu_chat_id_aqui
